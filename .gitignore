# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore real secrets, but allow the example template
.env
.env.local
.env.development
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# SQLite database — contains personal data (LinkedIn cookies, lead lists)
*.db
*.db-shm
*.db-wal

# Runtime log file
log.txt

# Temporary / personal dev scripts — not useful to others
scripts/tmp/

# Playwright browser cache (downloaded automatically on first run)
/playwright-browsers

# Docker volume mount — contains the SQLite DB when running via docker-compose
/data
