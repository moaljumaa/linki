# Copy this file to .env.local and fill in your values

# NextAuth — generate secret with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Password to log in to the Linki UI
AUTH_PASSWORD=

# SQLite database path (optional — defaults to ./linki.db in cwd)
# When running via Docker, this is set automatically to /data/linki.db
LINKI_DB_PATH=

# Set to "false" to show the browser window during automation (useful for debugging)
HEADLESS=true
